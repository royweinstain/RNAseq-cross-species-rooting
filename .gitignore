# Excel/Word temp files
~$*

# Pipeline output (regenerated by pipeline)
pipeline/output/

# Large data directories (downloadable from public databases)
pipeline/reference_genomes/
pipeline/orthogroups/proteomes/
reference_genomes/

# Raw sequencing data (download from SRA)
pipeline/datasets/*/raw/fastq/
pipeline/datasets/*/raw/bam/
*.fastq.gz
*.bam
*.bam.bai
*.sam

# Large binary/genome files
*.fa
*.fa.gz
*.faa
*.gtf

# Root-level files (not part of pipeline)
/*.xlsx
/*.docx
/*.csv

# Argan raw Excel (old XLOC-based, superseded by counts)
pipeline/datasets/argan_196_vs_YM3/raw/*.xlsx

# SRA download scripts (local-use only)
pipeline/datasets/argan_196_vs_YM3/download_one.sh
pipeline/datasets/argan_196_vs_YM3/download_sra.sh

# featureCounts raw output (intermediate)
pipeline/datasets/argan_196_vs_YM3/processed/argan_counts_raw.txt
pipeline/datasets/argan_196_vs_YM3/processed/argan_counts_raw.txt.summary

# Claude project files
.claude/

# Python
__pycache__/
*.pyc

# OS files
Thumbs.db
.DS_Store
